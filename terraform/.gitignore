# Downloaded provider binaries — regenerated by `terraform init`, never commit.
.terraform/

# State files — all envs use remote state (S3). Local tfstate should not exist
# during normal use. Back up terraform/envs/backend/terraform.tfstate manually.
*.tfstate
*.tfstate.backup

# Plan files — generated on demand, not stored in git.
*.tfplan

# .terraform.lock.hcl is intentionally NOT ignored.
# It pins provider versions (like package-lock.json) and must be committed.

# terraform.tfvars files are intentionally NOT ignored.
# They only contain non-sensitive config. Real secrets live in Secrets Manager.

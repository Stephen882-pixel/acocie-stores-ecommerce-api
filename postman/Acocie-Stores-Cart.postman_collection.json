{
  "info": {
    "name": "Acocie Stores – Cart",
    "_postman_id": "acocie-cart-collection-v1",
    "description": "Cart endpoints for the Acocie Stores API.\nBase URL variable: {{baseUrl}}  (default: http://localhost:5000/api/v1)\n\nGuest carts use a sessionId in the request body.\nAuthenticated carts use the {{accessToken}} bearer token.\nAfter merging carts, clear the sessionId variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "sessionId", "value": "guest-session-abc123", "type": "string" },
    { "key": "cartItemId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart (Guest)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            },
            "description": "Retrieve guest cart. No authentication required."
          },
          "response": []
        },
        {
          "name": "Get Cart (Authenticated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            },
            "description": "Retrieve the authenticated user's cart."
          },
          "response": []
        },
        {
          "name": "Add Item to Cart (Guest)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.items && res.data.items.length > 0) {",
                  "  pm.collectionVariables.set('cartItemId', res.data.items[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/items",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"<product-uuid>\",\n  \"variantId\": null,\n  \"quantity\": 2,\n  \"sessionId\": \"{{sessionId}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Add Item to Cart (Authenticated)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/items",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"<product-uuid>\",\n  \"variantId\": null,\n  \"quantity\": 1\n}"
            }
          },
          "response": []
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/items/{{cartItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items", "{{cartItemId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3,\n  \"sessionId\": \"{{sessionId}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart/items/{{cartItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items", "{{cartItemId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Validate Cart",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart/validate",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "validate"]
            },
            "description": "Check cart items for stock availability and pricing accuracy."
          },
          "response": []
        },
        {
          "name": "Merge Guest Cart into User Cart (Authenticated)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/merge",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "merge"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "description": "Call this after login to merge the guest cart into the user's persistent cart."
          },
          "response": []
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cart/clear",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "clear"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}

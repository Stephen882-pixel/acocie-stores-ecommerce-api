{
  "info": {
    "name": "Acocie Stores – Checkout",
    "_postman_id": "acocie-checkout-collection-v1",
    "description": "Checkout endpoints for the Acocie Stores API.\nBase URL variable: {{baseUrl}}  (default: http://localhost:5000/api/v1)\nAll checkout endpoints require authentication ({{accessToken}}).\n\nTypical flow:\n1. Initiate Checkout\n2. Get Checkout Summary (with shippingAddressId)\n3. Place Order",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "shippingAddressId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Initiate Checkout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/checkout/initiate",
              "host": ["{{baseUrl}}"],
              "path": ["checkout", "initiate"]
            },
            "description": "Validates the cart and prepares the checkout session."
          },
          "response": []
        },
        {
          "name": "Get Checkout Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/checkout/summary?shippingAddressId={{shippingAddressId}}",
              "host": ["{{baseUrl}}"],
              "path": ["checkout", "summary"],
              "query": [
                { "key": "shippingAddressId", "value": "{{shippingAddressId}}", "description": "UUID of the shipping address to calculate shipping cost" }
              ]
            },
            "description": "Returns order totals, shipping estimate, and applied discounts."
          },
          "response": []
        },
        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.orderNumber) {",
                  "  console.log('Order placed:', res.data.orderNumber);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/checkout/place-order",
              "host": ["{{baseUrl}}"],
              "path": ["checkout", "place-order"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddressId\": \"{{shippingAddressId}}\",\n  \"billingAddressId\": null,\n  \"paymentMethod\": \"cash_on_delivery\",\n  \"notes\": \"Please leave at the door.\"\n}"
            },
            "description": "Converts the current cart into a confirmed order.\npaymentMethod options: cash_on_delivery | card | mobile_money | bank_transfer"
          },
          "response": []
        }
      ]
    }
  ]
}

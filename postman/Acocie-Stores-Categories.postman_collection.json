{
  "info": {
    "name": "Acocie Stores – Categories",
    "_postman_id": "acocie-categories-collection-v1",
    "description": "Category endpoints for the Acocie Stores API.\nBase URL variable: {{baseUrl}}  (default: http://localhost:5000/api/v1)\nAdmin actions require {{accessToken}} to be set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "categoryId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"],
              "query": [
                { "key": "includeInactive", "value": "false", "description": "true | false", "disabled": true },
                { "key": "nested", "value": "true", "description": "Return as nested tree (true | false)", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "{{categoryId}}"],
              "query": [
                { "key": "includeProducts", "value": "true", "description": "true | false", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Category (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) pm.collectionVariables.set('categoryId', res.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic devices and accessories\",\n  \"parentId\": null,\n  \"imageUrl\": \"https://example.com/images/electronics.jpg\",\n  \"isActive\": true,\n  \"displayOrder\": 1,\n  \"metaTitle\": \"Electronics – Acocie Stores\",\n  \"metaDescription\": \"Browse the best electronics on Acocie Stores.\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "{{categoryId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics & Gadgets\",\n  \"isActive\": true,\n  \"displayOrder\": 2\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "{{categoryId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}

NODE_ENV=production
PORT=5002

DB_HOST=localhost
DB_PORT=5432
DB_NAME=acocie_stores
DB_USER=postgres
DB_PASSWORD=your_db_password_here


JWT_SECRET=generate_with_openssl_rand_base64_32
JWT_REFRESH_SECRET=generate_with_openssl_rand_base64_32
JWT_ACCESS_SECRET=generate_with_openssl_rand_base64_32
JWT_ACCESS_EXPIRY=60m
JWT_REFRESH_EXPIRY=7d



EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM="Acocie Stores <noreply@acocie.com>"


FRONTEND_URL=http://localhost:3001



AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-central-1
AWS_S3_BUCKET=acocie
# Optional: override public URL (e.g. CloudFront CDN)
# AWS_S3_BASE_URL=https://cdn.yourdomain.com